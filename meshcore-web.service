[Unit]
Description=MeshCore Webserver
After=network.target meshcore-hub.service

[Service]
User=pi
WorkingDirectory=/home/pi/meshcore-hub
ExecStart=/home/pi/meshcore-hub/venv/bin/python3 /home/pi/meshcore-hub/webserver.py
Restart=always
RestartSec=10
Environment=PYTHONUNBUFFERED=1

[Install]
WantedBy=multi-user.target
